# Copiá este archivo como `.env.local` y completá con los datos de tu proyecto Supabase.
# Los encontrás en: Supabase > Project Settings > API
# .env.local está ignorado por git (no se sube al repo).

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# Notificaciones push (Web Push). Generá el par de claves con:
#   npx web-push generate-vapid-keys
# La PÚBLICA va acá; la PRIVADA va en los secrets de la Edge Function (no acá).
VITE_VAPID_PUBLIC_KEY=tu-clave-vapid-publica
